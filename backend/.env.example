# Sporthink Dashboard - Ortam Degiskenleri
# Bu dosyayi kopyalayip .env olarak adlandirin
# .env dosyasini asla git'e commit etmeyin!

# Admin kullanici bilgileri (kendi bilgilerinizi girin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=guclu_sifrenizi_buraya_yazin
ADMIN_NAME=Admin Kullanici

# JWT gizli anahtari - rastgele uzun bir string girin
JWT_SECRET=buraya_en_az_32_karakter_rastgele_bir_string_yazin

# JWT token suresi
JWT_EXPIRES_IN=8h

# Sunucu portu
PORT=3001

# Frontend URL (CORS icin)
ALLOWED_ORIGIN=http://localhost:5173

# Python yolu (Windows icin)
PYTHON_CMD=C:\Python314\python.exe

# Master Data yolu
# MASTER_DATA_PATH=C:\Users\samet\Desktop\sporthink dashboard\sporthink\data\Ornek_Duzenli_Data.xlsx
